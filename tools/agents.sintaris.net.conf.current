# nginx reverse proxy for agents.sintaris.net
# Pi1 (OpenClawPI)  Ă”Ă‡Ă¶ SSH tunnel VPS:127.0.0.1:8082 Ă”ĂĄĂ† Pi1:8080 Ă”ĂĄĂ† /taris/
# Pi2 (OpenClawPI2) Ă”Ă‡Ă¶ SSH tunnel VPS:127.0.0.1:8084 Ă”ĂĄĂ† Pi2:8080 Ă”ĂĄĂ† /taris2/
#
# Deployed by install_vps.sh (substitutes agents.sintaris.net at deploy time)

map $http_upgrade $connection_upgrade {
    default upgrade;
    ''      close;
}

server {
    listen 80;
    listen [::]:80;
    server_name agents.sintaris.net;

    location /.well-known/acme-challenge/ {
        root /var/www/html;
    }
    location / {
        return 301 https://$host$request_uri;
    }
}

server {
    listen 443 ssl http2;
    listen [::]:443 ssl http2;
    server_name agents.sintaris.net;

    ssl_certificate     /etc/letsencrypt/live/agents.sintaris.net/fullchain.pem;   # managed by Certbot
    ssl_certificate_key /etc/letsencrypt/live/agents.sintaris.net/privkey.pem;     # managed by Certbot
    include             /etc/letsencrypt/options-ssl-nginx.conf;           # managed by Certbot
    ssl_dhparam         /etc/letsencrypt/ssl-dhparams.pem;                # managed by Certbot

    # gzip must stay off Ă”Ă‡Ă¶ sub_filter needs uncompressed HTML to rewrite paths
    gzip off;

    # Ă”Ă¶Ă‡Ă”Ă¶Ă‡ Pi1 Ă”Ă‡Ă¶ OpenClawPI Ă”Ă‡Ă¶ /taris/ Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡
    # Backwards compatibility: redirect old /picoassist paths to /taris
    location = /picoassist  { return 301 /taris/; }
    location /picoassist/   { return 301 /taris/$request_uri; }

    location = /taris { return 301 /taris/; }

    location /taris/ {
        proxy_pass            http://127.0.0.1:8082/;

        proxy_set_header      Host               $host;
        proxy_set_header      X-Real-IP          $remote_addr;
        proxy_set_header      X-Forwarded-For    $proxy_add_x_forwarded_for;
        proxy_set_header      X-Forwarded-Proto  $scheme;
        proxy_set_header      Accept-Encoding    "";       # keep upstream uncompressed for sub_filter

        proxy_http_version    1.1;
        proxy_set_header      Upgrade            $http_upgrade;
        proxy_set_header      Connection         $connection_upgrade;

        proxy_read_timeout    300s;
        proxy_send_timeout    300s;
        proxy_connect_timeout 10s;
        proxy_buffering       off;
        client_max_body_size  20m;

        # Rewrite absolute paths in HTML so the browser stays under /taris/
        sub_filter 'href="/'      'href="/taris/';
        sub_filter 'src="/'       'src="/taris/';
        sub_filter 'action="/'    'action="/taris/';
        sub_filter 'hx-get="/'    'hx-get="/taris/';
        sub_filter 'hx-post="/'   'hx-post="/taris/';
        sub_filter 'hx-put="/'    'hx-put="/taris/';
        sub_filter 'hx-delete="/' 'hx-delete="/taris/';
        sub_filter_once     off;
        sub_filter_types    text/html;
        proxy_redirect      http://127.0.0.1:8082/ /taris/;
        proxy_redirect      /                        /taris/;
    }

    # Ă”Ă¶Ă‡Ă”Ă¶Ă‡ Pi2 Ă”Ă‡Ă¶ OpenClawPI2 Ă”Ă‡Ă¶ /taris2/ Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡
    # Backwards compatibility: redirect old /picoassist2 paths to /taris2
    location = /picoassist2  { return 301 /taris2/; }
    location /picoassist2/   { return 301 /taris2/$request_uri; }

    location = /taris2 { return 301 /taris2/; }

    location /taris2/ {
        proxy_pass            https://127.0.0.1:8084/;
        proxy_ssl_verify      off;

        proxy_set_header      Host               $host;
        proxy_set_header      X-Real-IP          $remote_addr;
        proxy_set_header      X-Forwarded-For    $proxy_add_x_forwarded_for;
        proxy_set_header      X-Forwarded-Proto  $scheme;
        proxy_set_header      Accept-Encoding    "";

        proxy_http_version    1.1;
        proxy_set_header      Upgrade            $http_upgrade;
        proxy_set_header      Connection         $connection_upgrade;

        proxy_read_timeout    300s;
        proxy_send_timeout    300s;
        proxy_connect_timeout 10s;
        proxy_buffering       off;
        client_max_body_size  20m;

        sub_filter 'href="/'      'href="/taris2/';
        sub_filter 'src="/'       'src="/taris2/';
        sub_filter 'action="/'    'action="/taris2/';
        sub_filter 'hx-get="/'    'hx-get="/taris2/';
        sub_filter 'hx-post="/'   'hx-post="/taris2/';
        sub_filter 'hx-put="/'    'hx-put="/taris2/';
        sub_filter 'hx-delete="/' 'hx-delete="/taris2/';
        sub_filter_once     off;
        sub_filter_types    text/html;
        proxy_redirect      https://127.0.0.1:8084/ /taris2/;
        proxy_redirect      /                        /taris2/;
    }
    # Ă”Ă¶Ă‡Ă”Ă¶Ă‡ OpenClaw Web UI Ă”Ă‡Ă¶ /openclaw/ Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡
    # SSH reverse tunnel: VPS:127.0.0.1:18789 Ă”ĂĄĂ‰ dev machine:18789
    location = /openclaw { return 301 /openclaw/; }

    location /openclaw/ {
        proxy_pass            http://127.0.0.1:18789/;

        proxy_set_header      Host               $host;
        proxy_set_header      X-Real-IP          $remote_addr;
        proxy_set_header      X-Forwarded-For    $proxy_add_x_forwarded_for;
        proxy_set_header      X-Forwarded-Proto  $scheme;

        proxy_http_version    1.1;
        proxy_set_header      Upgrade            $http_upgrade;
        proxy_set_header      Connection         $connection_upgrade;

        proxy_read_timeout    300s;
        proxy_send_timeout    300s;
        proxy_connect_timeout 10s;
        proxy_buffering       off;
        client_max_body_size  20m;
    }

    # Ă”Ă¶Ă‡Ă”Ă¶Ă‡ SintAItion Ă”Ă‡Ă¶ /supertaris/ Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡
    # SSH tunnel VPS:127.0.0.1:8086 Ă”ĂĄĂ† SintAItion:8080 Ă”ĂĄĂ† supertaris
    location = /supertaris { return 301 /supertaris/; }

    location /supertaris/ {
        proxy_pass            http://127.0.0.1:8086/;

        proxy_set_header      Host               $host;
        proxy_set_header      X-Real-IP          $remote_addr;
        proxy_set_header      X-Forwarded-For    $proxy_add_x_forwarded_for;
        proxy_set_header      X-Forwarded-Proto  $scheme;
        proxy_set_header      Accept-Encoding    "";

        proxy_http_version    1.1;
        proxy_set_header      Upgrade            $http_upgrade;
        proxy_set_header      Connection         $connection_upgrade;

        proxy_read_timeout    300s;
        proxy_send_timeout    300s;
        proxy_connect_timeout 10s;
        proxy_buffering       off;
        client_max_body_size  20m;

        sub_filter 'href="/'      'href="/supertaris/';
        sub_filter 'src="/'       'src="/supertaris/';
        sub_filter 'action="/'    'action="/supertaris/';
        sub_filter 'hx-get="/'    'hx-get="/supertaris/';
        sub_filter 'hx-post="/'   'hx-post="/supertaris/';
        sub_filter 'hx-put="/'    'hx-put="/supertaris/';
        sub_filter 'hx-delete="/' 'hx-delete="/supertaris/';
        sub_filter_once     off;
        sub_filter_types    text/html;
        proxy_redirect      http://127.0.0.1:8086/ /supertaris/;
        proxy_redirect      /                       /supertaris/;
    }

    # Ă”Ă¶Ă‡Ă”Ă¶Ă‡ TariStation2 Ă”Ă‡Ă¶ /supertaris2/ Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡Ă”Ă¶Ă‡
    # SSH tunnel VPS:127.0.0.1:8088 Ă”ĂĄĂ† TariStation2:8080 (via SintAItion relay)
    location = /supertaris2 { return 301 /supertaris2/; }

    location /supertaris2/ {
        proxy_pass            http://127.0.0.1:8088/;

        proxy_set_header      Host               $host;
        proxy_set_header      X-Real-IP          $remote_addr;
        proxy_set_header      X-Forwarded-For    $proxy_add_x_forwarded_for;
        proxy_set_header      X-Forwarded-Proto  $scheme;
        proxy_set_header      Accept-Encoding    "";

        proxy_http_version    1.1;
        proxy_set_header      Upgrade            $http_upgrade;
        proxy_set_header      Connection         $connection_upgrade;

        proxy_read_timeout    300s;
        proxy_send_timeout    300s;
        proxy_connect_timeout 10s;
        proxy_buffering       off;
        client_max_body_size  20m;

        sub_filter 'href="/'      'href="/supertaris2/';
        sub_filter 'src="/'       'src="/supertaris2/';
        sub_filter 'action="/'    'action="/supertaris2/';
        sub_filter 'hx-get="/'    'hx-get="/supertaris2/';
        sub_filter 'hx-post="/'   'hx-post="/supertaris2/';
        sub_filter 'hx-put="/'    'hx-put="/supertaris2/';
        sub_filter 'hx-delete="/' 'hx-delete="/supertaris2/';
        sub_filter_once     off;
        sub_filter_types    text/html;
        proxy_redirect      http://127.0.0.1:8088/ /supertaris2/;
        proxy_redirect      /                       /supertaris2/;
    }

}
