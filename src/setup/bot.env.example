# bot.env — Telegram bot secrets for taris service
# Copy to ~/.taris/bot.env and fill in the real values.
# Two deployment variants are supported:
#   DEVICE_VARIANT=picoclaw  →  Raspberry Pi + PicoClaw robot arm (default)
#   DEVICE_VARIANT=openclaw  →  Laptop / Mini-PC + OpenClaw AI gateway

BOT_TOKEN=<your_telegram_bot_token_from_botfather>
ALLOWED_USER=<your_telegram_chat_id>

# ─────────────────────────────────────────────────────────────────────────────
# Deployment variant — set to 'picoclaw' (Pi) or 'openclaw' (PC/laptop)
# ─────────────────────────────────────────────────────────────────────────────
DEVICE_VARIANT=picoclaw

# ─────────────────────────────────────────────────────────────────────────────
# LLM provider — taris | openai | yandexgpt | gemini | anthropic | openclaw | local
# On PicoClaw: taris or openai recommended.
# On OpenClaw: openclaw (routes to GPT-5+ via local gateway) or openai.
# ⚠ Loop prevention: if LLM_PROVIDER=openclaw, skill-taris in sintaris-openclaw
#   must NOT forward chat requests back to this bot (infinite loop).
# ─────────────────────────────────────────────────────────────────────────────
LLM_PROVIDER=taris

# ─────────────────────────────────────────────────────────────────────────────
# OpenClaw integration — only needed when DEVICE_VARIANT=openclaw
# ─────────────────────────────────────────────────────────────────────────────
# OPENCLAW_BIN=~/.local/bin/openclaw       # path to openclaw binary
# OPENCLAW_SESSION=taris                   # session name for openclaw agent
# OPENCLAW_TIMEOUT=60                      # LLM timeout in seconds
# TARIS_API_TOKEN=<strong_random_token>    # Bearer token for /api/status and /api/chat
#                                          # Must match api-keys.txt in skill-taris

# ─────────────────────────────────────────────────────────────────────────────
# RAG / Knowledge base — FTS5 local search
# ─────────────────────────────────────────────────────────────────────────────
# RAG_ENABLED=1       # 1=on, 0=off
# RAG_TOP_K=3         # number of chunks injected per LLM call
# RAG_CHUNK_SIZE=512  # characters per chunk when indexing

# ─────────────────────────────────────────────────────────────────────────────
# Nextcloud remote backup (§6.3.3)
# ─────────────────────────────────────────────────────────────────────────────
NEXTCLOUD_URL=https://cloud.example.com
NEXTCLOUD_USER=<nextcloud_username>
NEXTCLOUD_PASS=<nextcloud_app_password>
NEXTCLOUD_REMOTE=/TarisBackups

# Cloud deploy server — used by update_from_cloud.sh
CLOUD_DEPLOY_URL=https://cloud.dev2null.de/taris
CLOUD_DEPLOY_TOKEN=
