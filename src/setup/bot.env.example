# bot.env — Taris bot secrets and configuration
# Copy to ~/.taris/bot.env and fill in the values.
# Two deployment variants are supported:
#   DEVICE_VARIANT=picoclaw  →  Raspberry Pi + PicoClaw (default)
#   DEVICE_VARIANT=openclaw  →  Laptop / Mini-PC + OpenClaw AI gateway
#
# After editing, restart the services:
#   systemctl --user restart taris-telegram taris-web

# ── Core — Telegram ──────────────────────────────────────────────────────────
BOT_TOKEN=<your_telegram_bot_token_from_botfather>
ALLOWED_USERS=<your_telegram_chat_id>          # comma-separated for multiple users
# ADMIN_USERS=<admin_telegram_chat_id>         # defaults to ALLOWED_USERS if unset

# ── Deployment variant ────────────────────────────────────────────────────────
# picoclaw — Raspberry Pi + Vosk STT + Piper TTS (offline voice)
# openclaw — Laptop/PC + faster-whisper STT + Piper TTS + Ollama LLM
DEVICE_VARIANT=openclaw

# ── LLM provider ─────────────────────────────────────────────────────────────
# Choices: taris | openai | ollama | yandexgpt | gemini | anthropic | openclaw | local
# Recommended:
#   PicoClaw:                     openai (no local GPU on Pi 3/4)
#   OpenClaw (TariStation2/CPU):  openai (i7-2640M — Ollama too slow for real-time)
#   OpenClaw (SintAItion/AMD GPU): ollama  ← USE THIS for best latency (~1.2 s local)
# ⚠ Loop: if LLM_PROVIDER=openclaw, skill-taris must NOT relay chat to this bot
# ⚠ Perf: LLM_PROVIDER=openai on GPU machines wastes local hardware and adds
#         1.5–8 s variable network latency. Switch to ollama when GPU is available.
LLM_PROVIDER=openai
# LLM_LOCAL_FALLBACK=1                   # 1 = try ollama if primary fails (recommended when openai is primary)

# ── OpenAI / cloud LLM ───────────────────────────────────────────────────────
# OPENAI_API_KEY=sk-...
# OPENAI_BASE_URL=https://api.openai.com/v1   # override for proxy / Azure
# OPENAI_MODEL=gpt-4o-mini

# ── Ollama (local LLM) ───────────────────────────────────────────────────────
# Required when LLM_PROVIDER=ollama or LLM_LOCAL_FALLBACK=1
# CPU install:  bash src/setup/setup_llm_openclaw.sh [--model qwen2:0.5b]
# GPU install:  bash src/setup/setup_llm_openclaw.sh --gpu [--model qwen3:14b]
# OLLAMA_URL=http://127.0.0.1:11434
# OLLAMA_MODEL=qwen2:0.5b                # CPU (i7-2640M):       qwen2:0.5b  ~300 ms
#                                        # GPU (Radeon 890M/16 GB): qwen3:14b ~1.2 s
# OLLAMA_MIN_TIMEOUT=90                  # minimum timeout (s); prevents cold-load timeouts
# OLLAMA_THINK=false                     # disable extended thinking for qwen3 models (REQUIRED — without this qwen3 returns empty responses via OpenAI-compat endpoint)
# OLLAMA_KEEP_ALIVE is set in the Ollama system service (1h default for GPU installs)

# ── Voice — STT (Speech-to-Text) ─────────────────────────────────────────────
# faster_whisper — default for openclaw; accurate, works without GPU
# vosk           — default for picoclaw; offline, low memory
# Install voice pipeline: bash src/setup/setup_voice_openclaw.sh
STT_PROVIDER=faster_whisper
# STT_LANG=ru                            # pin to one language: ru | en | de | sl
                                         # leave unset (or empty) for auto-detect (recommended for multilingual use)
# STT_FALLBACK_PROVIDER=vosk             # fallback if primary fails (disabled on openclaw)

# faster-whisper settings (STT_PROVIDER=faster_whisper)
FASTER_WHISPER_MODEL=base                # tiny | base | small | medium | large
                                         # SintAItion/GPU: small or medium (GPU handles it)
FASTER_WHISPER_DEVICE=cpu                # cpu | cuda
                                         # For AMD GPU (ROCm): set cuda — faster-whisper uses
                                         # CUDA compat layer from Ollama ROCm libs.
                                         # ALSO requires env vars in systemd service:
                                         #   HSA_OVERRIDE_GFX_VERSION=11.0.3
                                         #   LD_LIBRARY_PATH=/usr/local/lib/ollama/rocm
                                         # See: doc/install-new-target.md §B.5-GPU
FASTER_WHISPER_COMPUTE=int8              # int8 (CPU) | float16 (GPU, faster) | float32

# Vosk model path (STT_PROVIDER=vosk or picoclaw)
# VOSK_MODEL_PATH=~/.taris/vosk-model-small-ru-0.22

# ── Voice — TTS (Text-to-Speech) ─────────────────────────────────────────────
# Piper TTS — required for voice replies, calendar TTS, notes read-aloud
# Install: bash src/setup/setup_voice_openclaw.sh
# ⚠ Must set PIPER_BIN + PIPER_MODEL — web UI and Telegram bot both use these.
#   Do NOT rely on /usr/local/bin/piper (may not exist on all hosts).
PIPER_BIN=~/.taris/piper/piper           # absolute path to piper binary
PIPER_MODEL=~/.taris/ru_RU-irina-medium.onnx  # Russian TTS model
# PIPER_MODEL_LOW=~/.taris/ru_RU-irina-low.onnx  # optional faster/lower quality model
# PIPER_MODEL_DE=~/.taris/de_DE-thorsten-medium.onnx  # German TTS model

# ── AMD GPU (ROCm) acceleration — SintAItion / Radeon 890M ──────────────────
# When running on a machine with an AMD GPU that has ROCm support (gfx1100+):
# 1. Set FASTER_WHISPER_DEVICE=cuda and FASTER_WHISPER_COMPUTE=float16 above
# 2. Add these to the systemd service Environment= lines (not here — in .service file):
#      HSA_OVERRIDE_GFX_VERSION=11.0.3
#      LD_LIBRARY_PATH=/usr/local/lib/ollama/rocm
# 3. Set LLM_PROVIDER=ollama with OLLAMA_MODEL=qwen3.5:latest  (100% quality RU/DE/EN/SL @ 13 t/s)
# The Ollama system service already sets these vars if installed with --gpu flag.
# See: doc/install-new-target.md §B.5-GPU and errors/perf-sintaition-2026-03-31.md

# ── Pipeline performance logging ─────────────────────────────────────────────
# Pipeline logs are written to ~/.taris/logs/pipeline_YYYY-MM-DD.jsonl automatically.
# View via Web UI admin panel or API:
#   GET /api/logs?date=YYYY-MM-DD&last_n=50
#   GET /api/logs/stats?date=YYYY-MM-DD
# No configuration needed — logging is always on.
# Log directory: ~/.taris/logs/  (created automatically)

# ── Web UI ────────────────────────────────────────────────────────────────────
# ROOT_PATH — required when running behind nginx sub-path reverse proxy
# /supertaris  → SintAItion (TS1, production)
# /supertaris2 → TariStation2 (TS2, engineering)
# /taris       → OpenClawPI (PI1, production Pi)
# /taris2      → OpenClawPI2 (PI2, engineering Pi)
# ROOT_PATH=/supertaris
# TARIS_API_TOKEN=<strong_random_token>  # Bearer token for /api/status and /api/chat

# ── OpenClaw integration ──────────────────────────────────────────────────────
# Required only when DEVICE_VARIANT=openclaw and LLM_PROVIDER=openclaw
# OPENCLAW_BIN=~/.local/bin/openclaw
# OPENCLAW_SESSION=taris
# OPENCLAW_TIMEOUT=60

# ── RAG / Knowledge base ──────────────────────────────────────────────────────
# RAG_ENABLED=1          # 1=on, 0=off
# RAG_TOP_K=3            # chunks injected per LLM call
# RAG_CHUNK_SIZE=512     # characters per chunk

# ── Embeddings ────────────────────────────────────────────────────────────────
# Leave EMBED_MODEL empty to disable (FTS5-only fallback, uses less RAM)
# On Pi 3 (1 GB RAM): EMBED_KEEP_RESIDENT=0  (unload after each use)
# On OpenClaw (≥8 GB RAM): EMBED_KEEP_RESIDENT=1  (keep in RAM)
# EMBED_MODEL=sentence-transformers/all-MiniLM-L6-v2   # ~90 MB, 384-dim
# EMBED_KEEP_RESIDENT=1
# EMBED_DIMENSION=384

# ── Nextcloud remote backup ───────────────────────────────────────────────────
NEXTCLOUD_URL=https://cloud.example.com
NEXTCLOUD_USER=<nextcloud_username>
NEXTCLOUD_PASS=<nextcloud_app_password>
NEXTCLOUD_REMOTE=/TarisBackups

# ── Cloud deploy server (update_from_cloud.sh) ───────────────────────────────
CLOUD_DEPLOY_URL=https://cloud.dev2null.de/taris
CLOUD_DEPLOY_TOKEN=
