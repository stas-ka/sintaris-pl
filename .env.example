# .env.example — All required environment variables for the taris workspace
# Copy to .env and fill in real values. NEVER commit .env to git.
# .env is listed in .gitignore.

# ── TariStation2 (Engineering target, IniCoS-1) ───────────────────────────────
ENG_TARGETHOST_IP=<ip-of-taristation2>
ENG_HOSTUSER=stas
ENG_HOSTPWD=<ssh-password-for-taristation2>
ENG_HOSTKEY=<ssh-hostkey-fingerprint-sha256>

# ── TariStation1 / SintAItion (Production target) ────────────────────────────
OPENCLAW1_HOST=SintAItion
OPENCLAW1_LAN_HOST=SintAItion
OPENCLAW1_LAN_IP=<lan-ip-of-sintaition>
OPENCLAW1_TAILSCALE_IP=<tailscale-ip-of-sintaition>
OPENCLAW1_USER=stas
OPENCLAW1PWD=<ssh-password-for-sintaition>
OPENCLAW1_HOSTKEY=<ssh-hostkey-fingerprint-sha256>

# ── VPS-Supertaris (agents.sintaris.net — internet-facing production, 🔴 shared public VPS) ──
# taris runs at https://agents.sintaris.net/supertaris/ (ROOT_PATH=/supertaris in bot.env)
# This VPS also hosts: PostgreSQL (shared DB), N8N, Nginx (reverse proxy for all bots)
# ALL deploy/system operations require explicit user confirmation — see SKILL.md VPS safety rules
VPS_HOST=<vps-hostname-or-ip>
VPS_USER=<vps-ssh-user>
VPS_PWD=<vps-ssh-password>
VPS_HOSTKEY=<ssh-hostkey-fingerprint-sha256>

# ── N8N (on VPS) ──────────────────────────────────────────────────────────────
VPS_N8N_HOST=https://<your-n8n-hostname>
VPS_N8N_API_KEY=<n8n-api-key-jwt>

# N8N Campaign webhook URLs (set after running: python tools/n8n/n8n_admin.py create-campaign)
N8N_CAMPAIGN_SELECT_WH=<vps-n8n-host>/webhook/taris-campaign-select
N8N_CAMPAIGN_SEND_WH=<vps-n8n-host>/webhook/taris-campaign-send

# N8N Credential IDs (instance-specific — find in N8N UI under Credentials)
VPS_N8N_CRED_GSHEETS=<n8n-credential-id-for-google-sheets>
VPS_N8N_CRED_GSHEETS_NAME=<google-sheets-credential-name-in-n8n>
VPS_N8N_CRED_OPENAI=<n8n-credential-id-for-openai>
VPS_N8N_CRED_OPENAI_NAME=<openai-credential-name-in-n8n>
VPS_N8N_CRED_GMAIL=<n8n-credential-id-for-gmail>
VPS_N8N_CRED_GMAIL_NAME=<gmail-credential-name-in-n8n>

# Google Sheets document IDs
VPS_GSHEET_CLIENTS_ID=<google-sheets-document-id-for-client-list>
VPS_GSHEET_CAMPAIGN_ID=<google-sheets-document-id-for-campaign-log>

# ── Outbound Webhook Authentication ──────────────────────────────────────────
# Applies to all call_webhook() calls (works with n8n, Make, Zapier, custom APIs)
# WEBHOOK_AUTH_TYPE: none | bearer | apikey | hmac | basic
WEBHOOK_AUTH_TYPE=none
WEBHOOK_AUTH_TOKEN=<token-or-user:pass-for-basic>
WEBHOOK_AUTH_HEADER=X-Api-Key     # header name for apikey auth (default: X-Api-Key)
WEBHOOK_HMAC_SECRET=<shared-secret-for-hmac-signing-and-inbound-verify>

# ── PostgreSQL (on VPS) ───────────────────────────────────────────────────────
VPS_PG_HOST=<vps-hostname-or-ip>
VPS_PG_PORT=5432
VPS_PG_USER=taris
VPS_PG_PASSWORD=<taris-user-postgres-password>
VPS_PG_DB=taris
VPS_PG_DB_VPS=taris_vps
STORE_PG_DSN=postgresql://taris:<password>@<host>:5432/taris

# ── PostgreSQL (SintAItion local — taris store) ───────────────────────────────
SINTAITION_PG_USER=taris_user
SINTAITION_PG_PASSWORD=<sintaition-taris-postgres-password>
SINTAITION_PG_DB=taris_db
SINTAITION_PG_HOST=127.0.0.1
SINTAITION_PG_PORT=5432
# SintAItion CRM → VPS PostgreSQL via SSH tunnel on port 15432; uses VPS_PG_PASSWORD

# ── Local PostgreSQL (TariStation install, set by install_openclaw.sh) ────────
TARIS_PG_PASSWORD=<postgres-password-for-local-docker>

# ── Telegram ──────────────────────────────────────────────────────────────────
BOT_TOKEN=<telegram-bot-token-from-botfather>
ALLOWED_USERS=<telegram-chat-ids-comma-separated>
ADMIN_USERS=<admin-telegram-chat-ids>
DEVELOPER_USERS=<developer-telegram-chat-ids>

# Guest / auto-registration (optional — leave unset to disable)
# AUTO_GUEST_ENABLED=1   → unknown users who /start the bot auto-register as guests
# AUTO_USER_ENABLED=1    → guests auto-promoted to user on first message
# GUEST_MSG_DAILY_LIMIT  → max LLM messages per guest per day (default: 20)
# GUEST_MSG_HOURLY_LIMIT → max LLM messages per guest per hour (default: 5)
# GUEST_MAX_TOKENS       → max LLM output tokens per guest request (default: 500)
# SHARED_DOCS_OWNER      → chat_id whose shared docs are visible to guests as RAG
AUTO_GUEST_ENABLED=0
AUTO_USER_ENABLED=0
GUEST_MSG_DAILY_LIMIT=20
GUEST_MSG_HOURLY_LIMIT=5
GUEST_MAX_TOKENS=500
SHARED_DOCS_OWNER=

# ── OpenAI ────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-<your-openai-key>

# ── Raspberry Pi targets (taris branch) ──────────────────────────────────────
DEV_HOSTPWD=<ssh-password-for-pi2>
DEV_TAILSCALE_IP=<tailscale-ip-of-pi2>
PROD_HOSTPWD=<ssh-password-for-pi1>
PROD_TAILSCALE_IP=<tailscale-ip-of-pi1>

VPS_HOSTKEY=<sha256-hostkey-for-vps-port-443>
