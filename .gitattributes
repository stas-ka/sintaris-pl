# Normalize all text files to LF line endings
* text=auto eol=lf

# Explicit overrides for key types
*.sh      text eol=lf
*.service text eol=lf
*.py      text eol=lf
*.json    text eol=lf
*.md      text eol=lf
*.txt     text eol=lf
*.html    text eol=lf
*.yaml    text eol=lf
*.yml     text eol=lf
*.css     text eol=lf
*.conf    text eol=lf
*.ini     text eol=lf
*.bat     text eol=lf
*.ps1     text eol=lf

# Binary files — no conversion
*.png     binary
*.jpg     binary
*.jpeg    binary
*.gif     binary
*.ico     binary
*.webp    binary
*.mp3     binary
*.wav     binary
*.ogg     binary
