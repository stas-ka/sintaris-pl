# Credentials — never commit
.credentials/
.env

# Python
__pycache__/
*.pyc
*.pyo

# Test artifacts — captured audio / raw recordings
src/tests/voice/audio_*
src/tests/voice/*.ogg
src/tests/voice/*.wav
src/tests/voice/*.pcm

# Backup snapshots — exclude large binary archives (100 MB+), keep manifests + checksums
backup/snapshots/**/picoclaw-full-*.tar.gz
backup/snapshots/**/picoclaw-scripts-*.tar.gz
backup/*.tar.gz

# Temp scratch files
temp/
nul
%TEMP%*
d?Temp*

# IDE agents
.github/agents/

# Large binary resources
src/res/

# You (scratch)
You

# SSL/TLS certificates (generated locally, never commit secrets)
deploy/certs/*.crt
deploy/certs/*.pem
deploy/certs/*.key
