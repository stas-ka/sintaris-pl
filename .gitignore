# Credentials — never commit
.credentials/
.env

# Python
__pycache__/
*.pyc
*.pyo

# Test artifacts — captured audio / raw recordings
src/tests/voice/audio_*
src/tests/voice/*.ogg
src/tests/voice/*.wav
src/tests/voice/*.pcm

# Backup snapshots — all snapshot directories excluded (contain large binaries + secrets)
backup/snapshots/
backup/*.tar.gz

# Media files accidentally placed in doc/
doc/*.jpg
doc/*.png
doc/*.ogg
doc/*.mp4

# Temp scratch files
temp/
nul
%TEMP%*
d?Temp*

# Generated deployment configs (contain real credentials — never commit)
# system-configs/ is allowed — it contains only templates and sanitized live configs
deploy/ts*/
deploy/pi*/
deploy/ocpi*/

# IDE / editor settings
.vscode/

# TLS certificates (local dev certs, not for version control)
*.crt
*.pem
*.key

# Backup tar archives in root (misplaced snapshots)
Projectsworkspace*.tar.gz

# Test run result JSON files
src/tests/voice/results/

# IDE agents
.github/agents/

# Large binary resources
res/

# You (scratch)
You
doc/todo/*.ogg
doc/todo/*.mp4
