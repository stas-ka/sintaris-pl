# .env.template — taris_kb database + N8N MCP KB configuration
# ARCHITECTURE (v0.3): MCP server = N8N MCP Server Trigger. No FastAPI container.
# Copy to /opt/taris-mcp-kb/.env (or use in bot.env / .env on Taris targets).
# NEVER commit the filled .env file.

# ── taris_kb PostgreSQL (separate DB, accessed by N8N Postgres nodes) ─────────
# Used in init_taris_kb.sql and optionally by benchmark scripts
KB_PG_DSN=postgresql://taris_kb_writer:<password>@127.0.0.1:5432/taris_kb

# ── N8N MCP Server (Taris client config) ──────────────────────────────────────
# MCP_REMOTE_URL: SSE endpoint of N8N MCP Server Trigger workflow
# Format: https://agents.sintaris.net/n8n/mcp/<workflow-path>/sse
MCP_REMOTE_URL=https://agents.sintaris.net/n8n/mcp/<workflow-path>/sse

# N8N API key for MCP Server authentication (X-N8N-API-Key header)
N8N_KB_API_KEY=<n8n-api-key>

# ── N8N Ingest Webhook (plain HTTP POST for file upload) ──────────────────────
N8N_KB_WEBHOOK_INGEST=https://agents.sintaris.net/n8n/webhook/<uuid>/kb-ingest
N8N_KB_TOKEN=<n8n-webhook-token>

# ── Taris-side feature gates ──────────────────────────────────────────────────
REMOTE_KB_ENABLED=0         # 1 = enable Remote KB agent/skill in Taris
REMOTE_KB_MODE=n8n           # n8n | google

# ── Phase 4: Google-grounded variant ─────────────────────────────────────────
# GOOGLE_CSE_KEY=<your-google-api-key>
# GOOGLE_CSE_CX=<your-custom-search-engine-id>
# VERTEX_PROJECT=<gcp-project-id>
# VERTEX_LOCATION=us-central1
