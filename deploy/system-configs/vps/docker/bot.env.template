# bot.env — Taris OpenClaw VPS Docker instance
# Deploy path: /opt/taris-docker/bot.env
# Copy from template and fill in all CHANGE_ME values.

# ── Telegram ──────────────────────────────────────────────────────────────────
BOT_TOKEN=CHANGE_ME                  # from @BotFather — create bot "Supertariss"
ALLOWED_USERS=CHANGE_ME              # comma-separated Telegram user IDs (e.g. 12345678)
ADMIN_USERS=CHANGE_ME                # subset of ALLOWED_USERS with admin access
BOT_NAME=Supertariss
DEVICE_VARIANT=openclaw

# ── LLM Provider ──────────────────────────────────────────────────────────────
# VPS has no GPU and insufficient RAM for local LLM — use OpenAI API
LLM_PROVIDER=openai
OPENAI_API_KEY=CHANGE_ME             # from platform.openai.com/api-keys
OPENAI_MODEL=gpt-4o-mini
LLM_FALLBACK_PROVIDER=openai
LLM_LOCAL_FALLBACK=0

# ── Voice pipeline (Telegram OGG files only — no live mic on VPS) ─────────────
STT_PROVIDER=faster_whisper
FASTER_WHISPER_MODEL=base            # RTF=0.23 on VPS ARM64; tiny for faster/less RAM
FASTER_WHISPER_DEVICE=cpu
FASTER_WHISPER_COMPUTE=int8
FASTER_WHISPER_THREADS=3             # VPS has 6 vCPU shared; limit to 3
FASTER_WHISPER_SPEECH_PAD_MS=200
FASTER_WHISPER_PRELOAD=0             # lazy load — saves RAM at idle
STT_FALLBACK_PROVIDER=vosk
STT_LANG=ru
PIPER_BIN=/opt/piper/piper           # mounted from /opt/taris-docker/data/piper/
PIPER_MODEL=/opt/piper/ru_RU-irina-medium.onnx

# ── Web UI ────────────────────────────────────────────────────────────────────
WEB_HOST=0.0.0.0
WEB_PORT=8090                        # informational — actual port set in docker-compose CMD
ROOT_PATH=/supertaris-vps            # sub-path prefix for nginx

# ── PostgreSQL backend ────────────────────────────────────────────────────────
STORE_BACKEND=postgres
STORE_PG_DSN=postgresql://taris:CHANGE_ME@127.0.0.1:5432/taris_vps

# ── CRM (VPS PostgreSQL direct — no tunnel needed, container is on VPS) ───────
CRM_PG_DSN=postgresql://taris:CHANGE_ME@127.0.0.1:5432/taris
CRM_ENABLED=1

# ── N8N Campaign ──────────────────────────────────────────────────────────────
N8N_URL=https://automata.dev2null.de
N8N_CAMPAIGN_SELECT_WH=https://automata.dev2null.de/webhook/taris-campaign-select
N8N_CAMPAIGN_SEND_WH=https://automata.dev2null.de/webhook/taris-campaign-send
N8N_CAMPAIGN_TIMEOUT=90
CAMPAIGN_SHEET_ID=CHANGE_ME
CAMPAIGN_DEMO_MODE=false
CAMPAIGN_FROM_EMAIL=info@sintaris.net

# ── Conversation ──────────────────────────────────────────────────────────────
CONVERSATION_HISTORY_MAX=8
LOCAL_MAX_TOKENS=512
