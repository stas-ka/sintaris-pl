# bot.env — TariStation2 (local engineering/development target) template
# Copy to ~/.taris/bot.env and fill in secrets marked with CHANGE_ME

# ── Telegram ──────────────────────────────────────────────────────────────────
BOT_TOKEN=CHANGE_ME
ALLOWED_USERS=CHANGE_ME
ADMIN_USERS=CHANGE_ME
BOT_NAME=SuperTaris2
DEVICE_VARIANT=openclaw

# ── LLM Provider ──────────────────────────────────────────────────────────────
LLM_PROVIDER=ollama
OLLAMA_URL=http://127.0.0.1:11434
OLLAMA_MODEL=qwen3.5:0.8b           # small model for CPU-only (7.6GB RAM); use e2b/e4b if GPU
OLLAMA_MIN_TIMEOUT=90
OLLAMA_THINK=false
OLLAMA_KEEP_ALIVE=1h
OLLAMA_NUM_CTX=4096
LLM_FALLBACK_PROVIDER=openai
LLM_LOCAL_FALLBACK=0
OPENAI_API_KEY=CHANGE_ME
OPENAI_MODEL=gpt-4o-mini

# ── Performance (IMPORTANT for low-RAM machine) ───────────────────────────────
FASTER_WHISPER_PRELOAD=0            # do NOT preload — prevents OOM with Ollama running

# ── Voice pipeline ────────────────────────────────────────────────────────────
STT_PROVIDER=faster_whisper
FASTER_WHISPER_MODEL=small
FASTER_WHISPER_DEVICE=cpu
FASTER_WHISPER_COMPUTE=int8
FASTER_WHISPER_THREADS=4
FASTER_WHISPER_SPEECH_PAD_MS=200
STT_LANG=ru
PIPER_BIN=/home/stas/.taris/piper/piper
PIPER_MODEL=/home/stas/.taris/ru_RU-irina-medium.onnx

# ── Web UI ────────────────────────────────────────────────────────────────────
WEB_HOST=0.0.0.0
WEB_PORT=8080
ROOT_PATH=/supertaris2              # sub-path in nginx for TariStation2

# ── Storage backend ───────────────────────────────────────────────────────────
STORE_BACKEND=postgres
STORE_PG_DSN=postgresql://taris_user:CHANGE_ME@127.0.0.1:5432/taris_db
# Or use sqlite for simple dev setup:
# STORE_BACKEND=sqlite
# STORE_DB_PATH=/home/stas/.taris/taris.db

# ── Conversation ──────────────────────────────────────────────────────────────
CONVERSATION_HISTORY_MAX=6
