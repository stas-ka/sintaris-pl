# bot.env — SintAItion (TariStation1) OpenClaw configuration template
# Copy to ~/.taris/bot.env and fill in secrets marked with CHANGE_ME
# Lines starting with # are comments and ignored.

# ── Telegram ──────────────────────────────────────────────────────────────────
BOT_TOKEN=CHANGE_ME                  # from @BotFather
ALLOWED_USERS=CHANGE_ME              # comma-separated Telegram user IDs
ADMIN_USERS=CHANGE_ME                # subset of ALLOWED_USERS with admin access
BOT_NAME=SuperTaris
DEVICE_VARIANT=openclaw

# ── LLM Provider ──────────────────────────────────────────────────────────────
LLM_PROVIDER=ollama
OLLAMA_URL=http://127.0.0.1:11434
OLLAMA_MODEL=gemma4:e4b              # AMD 890M GPU fits e4b (5GB); use e2b on weaker GPU
OLLAMA_MIN_TIMEOUT=120
OLLAMA_THINK=false
OLLAMA_KEEP_ALIVE=24h
OLLAMA_NUM_CTX=8192
LLM_FALLBACK_PROVIDER=openai
LLM_LOCAL_FALLBACK=0
OPENAI_API_KEY=CHANGE_ME             # for fallback (gpt-4o-mini)
OPENAI_MODEL=gpt-4o-mini

# ── Voice pipeline ────────────────────────────────────────────────────────────
STT_PROVIDER=faster_whisper
FASTER_WHISPER_MODEL=small           # small=best all-round; large-v3-turbo=better DE but >1x realtime
FASTER_WHISPER_DEVICE=cpu            # cpu=safer; cuda if NVIDIA GPU available
FASTER_WHISPER_COMPUTE=int8          # int8 best for cpu
FASTER_WHISPER_THREADS=12            # match CPU core count
FASTER_WHISPER_SPEECH_PAD_MS=200
STT_LANG=ru                          # primary language: ru | en | de
PIPER_BIN=/home/stas/.taris/piper/piper
PIPER_MODEL=/home/stas/.taris/ru_RU-irina-medium.onnx

# ── Web UI ────────────────────────────────────────────────────────────────────
WEB_HOST=0.0.0.0
WEB_PORT=8080
ROOT_PATH=/supertaris                # sub-path prefix for nginx reverse proxy

# ── PostgreSQL backend (local) ────────────────────────────────────────────────
STORE_BACKEND=postgres
STORE_PG_DSN=postgresql://taris_user:CHANGE_ME@127.0.0.1:5432/taris_db

# ── CRM via VPS SSH tunnel ────────────────────────────────────────────────────
# taris-pg-tunnel.service binds local 15432 → VPS 5432
CRM_PG_DSN=postgresql://taris:CHANGE_ME@127.0.0.1:15432/taris
CRM_ENABLED=1

# ── N8N Campaign ──────────────────────────────────────────────────────────────
N8N_URL=https://automata.dev2null.de
N8N_CAMPAIGN_SELECT_WH=https://automata.dev2null.de/webhook/taris-campaign-select
N8N_CAMPAIGN_SEND_WH=https://automata.dev2null.de/webhook/taris-campaign-send
N8N_CAMPAIGN_TIMEOUT=90
CAMPAIGN_SHEET_ID=CHANGE_ME          # Google Sheets spreadsheet ID
CAMPAIGN_DEMO_MODE=false
CAMPAIGN_FROM_EMAIL=info@sintaris.net

# ── Mail / IMAP (optional) ────────────────────────────────────────────────────
# IMAP_HOST=imap.example.com
# IMAP_USER=user@example.com
# IMAP_PASS=CHANGE_ME
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=user@example.com
# SMTP_PASS=CHANGE_ME

# ── Conversation ──────────────────────────────────────────────────────────────
CONVERSATION_HISTORY_MAX=8
