[Unit]
Description=SSH Tunnel to VPS PostgreSQL for Taris CRM
After=network-online.target

[Service]
Type=simple
ExecStart=/usr/bin/ssh -NL 15432:127.0.0.1:5432 stas@dev2null.de -i /home/stas/.ssh/vps_tunnel_key -o StrictHostKeyChecking=no -o ServerAliveInterval=60 -o ServerAliveCountMax=3 -o ExitOnForwardFailure=yes
Restart=always
RestartSec=10

[Install]
WantedBy=default.target
